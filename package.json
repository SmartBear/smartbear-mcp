{
  "name": "@smartbear/mcp",
  "version": "0.32.0",
  "description": "MCP server for interacting SmartBear Products",
  "keywords": [
    "smartbear",
    "mcp",
    "bugsnag",
    "reflect",
    "swagger",
    "pactflow",
    "zephyr",
    "qtm4j"
  ],
  "homepage": "https://developer.smartbear.com/smartbear-mcp",
  "mcpName": "com.smartbear/smartbear-mcp",
  "repository": {
    "type": "git",
    "url": "git@github.com:SmartBear/smartbear-mcp.git"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "assets",
    "**/README.md"
  ],
  "config": {
    "mcpServerName": "SmartBear MCP Server"
  },
  "scripts": {
    "build": "tsc && vite build && shx chmod +x dist/*.js",
    "build:mcpb": "npm run build && node scripts/pack-mcpb.js",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --fix",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "prepare": "npm run build",
    "watch": "vite build --watch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:coverage:ci": "vitest --coverage --reporter=verbose",
    "test:run": "vitest run",
    "test:pact": "vitest run --config vitest.pact.config.ts",
    "coverage:check": "vitest --coverage --reporter=verbose",
    "bump": "node scripts/bump.js"
  },
  "dependencies": {
    "@bugsnag/js": "^8.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "js-yaml": "^4.2.0",
    "node-cache": "^5.1.2",
    "swagger-client": "^3.37.1",
    "vite": "^7.3.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@pact-foundation/pact": "^17.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.10",
    "globals": "^16.5.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "vitest-fetch-mock": "^0.4.5"
  }
}
