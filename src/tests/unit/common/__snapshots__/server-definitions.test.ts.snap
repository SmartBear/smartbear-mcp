      "limit",
      "page",
      "projectKey",
      "releaseID",
      "rqID",
      "showEntityWithReleaseCycle",
      "start",
      "tcFolderPath",
    ],
    "outputSchema": undefined,
    "title": "QMetry: Fetch Test Cases Linked to Requirement",
